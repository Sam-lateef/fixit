DATABASE_URL=postgresql://user:password@localhost:5432/fixit
JWT_SECRET=change_me_to_long_random_string
JWT_EXPIRES_IN=30d
PORT=3000
# Set to 1 to log GET/PUT /api/v1/shops/me (shop id, name, cover URL hint) — pair with Metro `[FixIt:ShopProfile]`
DEBUG_SHOP_PROFILE=
API_URL=http://localhost:3000
# Optional: public origin for URLs returned to mobile (uploads, etc.). Use when API_URL is localhost
# but phones hit the API via LAN IP or HTTPS (e.g. https://fixit-api.fly.dev). Falls back to request Host.
API_PUBLIC_URL=
APP_URL=http://localhost:5173

# Phone OTP (Iraq) — Infobip removed; /auth/send-otp uses otpiq when OTPIQ_API_KEY is set.
OTPIQ_API_KEY=
# OTPIQ_SENDER_ID=

# Issues JWT for dev users (+9647000000001 owner / +9647000000002 shop). Never in production.
DEV_ALLOW_SESSION_LOGIN=

# Development only: accept this OTP for any phone (never enable in production)
DEV_OTP_BYPASS_CODE=

# Dev without a real phone: set all three. Mock number must stay +9647XXXXXXXXX.
# App shows "Continue without SMS" when VITE_DEV_MOCK_AUTH=true (see app/.env.example).
DEV_ALLOW_MOCK_AUTH=
DEV_MOCK_PHONE=+9647000000000

# Firebase Admin — same project as mobile EXPO_PUBLIC_FIREBASE_*. Do not paste the web SDK snippet here.
# A) Paste full JSON string here, or B) save download as repo-root firebase-service-account.json (gitignored), or C) FIREBASE_SERVICE_ACCOUNT_PATH=...
# Required for FCM push and POST /api/v1/auth/firebase. On Fly use: fly secrets set FIREBASE_SERVICE_ACCOUNT_JSON='...' (image has no repo root file).
FIREBASE_SERVICE_ACCOUNT_JSON=

# Cloudflare R2 (recommended for photo uploads)
# R2_ACCOUNT_ID: Dashboard → R2 → right column, or any R2 API example URL
# R2_ACCESS_KEY_ID / R2_SECRET_ACCESS_KEY: R2 → Overview → Manage R2 API Tokens → Create API token
#   (Permissions: Object Read & Write; scope to your bucket)
# R2_BUCKET_NAME: name of the bucket you created under R2
# R2_PUBLIC_URL: public base URL with NO trailing slash — e.g. https://pub-xxxx.r2.dev
#   (Bucket → Settings → Public access → R2.dev subdomain, or connect a custom domain)
# Optional override if Cloudflare gives a different S3 endpoint:
# R2_ENDPOINT=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=fixit-photos
R2_PUBLIC_URL=

# Local uploads fallback when R2_* is not fully set. Stored URLs use API_PUBLIC_URL, else request Host, else API_URL + /uploads/
LOCAL_UPLOAD_DIR=./uploads
