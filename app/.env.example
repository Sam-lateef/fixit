# Dev: Vite proxies /api to API. For device builds set full URL:
VITE_API_URL=

# “Admin login” on the marketing landing (`#/coming-soon`).
# Preferred in prod: set API `ADMIN_LOGIN_URL` (see api/.env.example) — no Vite rebuild.
# Optional bake-time override:
# VITE_ADMIN_LOGIN_URL=https://your-admin-host/login

# Car owner sign-in on web (`#/auth/welcome`) — same Firebase web app as mobile (EXPO_PUBLIC_FIREBASE_* there).
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=

# Show "Continue without SMS (mock number)" on the phone screen (npm run dev only).
# Requires api: DEV_ALLOW_MOCK_AUTH=true, DEV_MOCK_PHONE, DEV_OTP_BYPASS_CODE.
VITE_DEV_MOCK_AUTH=true
# Optional; must match api DEV_MOCK_PHONE
VITE_DEV_MOCK_PHONE=+9647000000000
