# Public vars (embedded at build time). Copy to `.env` for local dev if you use a dotenv loader, or set in shell.

# API origin (required in production).
# Dev fallback: Metro host IP + :3000 (works for many setups). If the app cannot reach the API from a
# physical Android device, set this explicitly to your PC’s LAN IP (same Wi‑Fi as the phone):
#   EXPO_PUBLIC_API_URL=http://192.168.1.10:3000
# Ensure the API is running (`npm run dev:api` from repo root) and Windows firewall allows port 3000.
#
# Local dev — PC LAN IP (physical phone; see ipconfig). Not localhost.
# EXPO_PUBLIC_API_URL=http://192.168.1.50:3000
#
# Production / Fly.io — HTTPS, no trailing slash (see tmp/fly-deploy.md)
# EXPO_PUBLIC_API_URL=https://your-app.fly.dev

# Mock OTP UI on the first screen (__DEV__ only). Default: shown. Opt out: EXPO_PUBLIC_DEV_MOCK_AUTH=false
# Match api/.env: DEV_ALLOW_MOCK_AUTH, DEV_MOCK_PHONE, DEV_OTP_BYPASS_CODE
# EXPO_PUBLIC_DEV_MOCK_PHONE=+9647000000000

# Optional: cold start opens /dev screen (__DEV__ only). Leave false for normal testing.
# EXPO_PUBLIC_DEV_NAV_HUB=true

# Shop: skip RevenueCat paywall in dev (__DEV__ only)
# EXPO_PUBLIC_DEV_SKIP_SHOP_PAYWALL=true

# Verbose `[FixIt:ShopProfile]` traces in Metro (printed as WARN). Set if you do not see shop logs.
# EXPO_PUBLIC_SHOP_PROFILE_LOGS=1

# Firebase Web app (Project settings → General → Your apps → Web app SDK snippet).
# Same project as api FIREBASE_SERVICE_ACCOUNT_JSON. Enable Google + Apple under Authentication.
EXPO_PUBLIC_FIREBASE_API_KEY=AIzaSyCKxmL6bYMnyto8Yjw7_T--emGeMVbMEIo
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=fixit-9191d.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=fixit-9191d
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=fixit-9191d.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=925833254957
EXPO_PUBLIC_FIREBASE_APP_ID=1:925833254957:web:ec6df23ac247360ad000a4
# Optional — Analytics only; not read by app auth code today.
# EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=G-GGQ0VKJGVW
# Google Sign-In: OAuth 2.0 Web client ID (Google Cloud → APIs & Credentials → Web client).
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=YOUR_WEB_CLIENT_ID.apps.googleusercontent.com
# Expo Go only: Google rejects exp:// redirect URIs. Use the AuthSession proxy — same value as
# `extra.originalFullName` after `npx expo login` (e.g. @jane/fixit). Add this exact redirect to the
# Web client's Authorized redirect URIs: https://auth.expo.io/@jane/fixit
# EXPO_PUBLIC_EXPO_PROJECT_FULL_NAME=@yourExpoUsername/fixit
# Native Google Sign-In (`@react-native-google-signin/google-signin`) — used when NOT in Expo Go
# (e.g. `npx expo run:android` / `expo run:ios`). Requires Android OAuth (package + SHA-1) and optional iOS client.
# Firebase SHA-1 must match the keystore Gradle uses: `android/app/debug.keystore` (see `npm run android:sha1`),
# not only `%USERPROFILE%\.android\debug.keystore` — they can differ and cause DEVELOPER_ERROR.
# Expo Go still uses Web client + https://auth.expo.io/… (see EXPO_PUBLIC_EXPO_PROJECT_FULL_NAME above).
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=YOUR_IOS_CLIENT_ID.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=YOUR_ANDROID_CLIENT_ID.apps.googleusercontent.com

# RevenueCat (public SDK keys) — use test_* keys from the dashboard in dev
# EXPO_PUBLIC_REVENUECAT_API_KEY_IOS=test_...
# EXPO_PUBLIC_REVENUECAT_API_KEY_ANDROID=test_...
# Must match entitlement id in RevenueCat (default in app: "FixIT Pro")
# EXPO_PUBLIC_REVENUECAT_ENTITLEMENT_ID=FixIT Pro
