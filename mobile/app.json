{
  "expo": {
    "name": "صلّحها",
    "slug": "fixit",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/fixit-icon-1024.png",
    "scheme": "fixit",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1B4332"
    },
    "ios": {
      "bundleIdentifier": "com.fixitiq.app",
      "buildNumber": "20",
      "supportsTablet": true,
      "icon": "./assets/images/fixit-icon-1024.png",
      "googleServicesFile": "./GoogleService-Info.plist",
      "splash": {
        "image": "./assets/images/splash-icon.png",
        "resizeMode": "contain",
        "backgroundColor": "#1B4332",
        "dark": {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#1B4332"
        }
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.fixitiq.app",
      "versionCode": 20,
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/fixit-adaptive-fg-1024.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "softwareKeyboardLayoutMode": "resize",
      "splash": {
        "image": "./assets/images/splash-icon.png",
        "resizeMode": "contain",
        "backgroundColor": "#1B4332",
        "dark": {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#1B4332"
        }
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/launcher-wrench-green.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#1B4332",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 220,
          "resizeMode": "contain",
          "dark": {
            "backgroundColor": "#1B4332",
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 220,
            "resizeMode": "contain"
          }
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "extraPods": [
              {
                "name": "GoogleUtilities",
                "modular_headers": true
              },
              {
                "name": "RecaptchaInterop",
                "modular_headers": true
              }
            ]
          }
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.925833254957-i4hat6onrq66lnbtbifma5ikte92mv9r"
        }
      ],
      "expo-apple-authentication",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "اسمح لصلّحها بإرفاق الصور إلى منشوراتك."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "اسمح لصلّحها باستخدام موقعك لطلبات السحب."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/fixit-notification-96.png",
          "color": "#2D6A4F",
          "defaultChannel": "default",
          "sounds": []
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "fixitApiBaseUrl": "",
      "router": {},
      "eas": {
        "projectId": "02e337fc-7c3b-4b61-9459-1d40caba2caa"
      }
    },
    "owner": "ekkoo"
  }
}
