{
  "expo": {
    "name": "صلّحها",
    "slug": "fixit",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/Fix.png",
    "scheme": "fixit",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "bundleIdentifier": "com.fixitiq.app",
      "supportsTablet": true,
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.fixit.app",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/Fix.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "softwareKeyboardLayoutMode": "pan"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "@react-native-google-signin/google-signin",
      "expo-apple-authentication",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "اسمح لصلّحها بإرفاق الصور إلى منشوراتك."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "اسمح لصلّحها باستخدام موقعك لطلبات السحب."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#2D6A4F",
          "sounds": []
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "fixitApiBaseUrl": "",
      "router": {},
      "eas": {
        "projectId": "02e337fc-7c3b-4b61-9459-1d40caba2caa"
      }
    },
    "owner": "ekkoo"
  }
}
