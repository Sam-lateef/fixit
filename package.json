{
  "name": "fixit",
  "private": true,
  "workspaces": [
    "api",
    "app",
    "mobile"
  ],
  "scripts": {
    "dev": "concurrently -n api,mobile -c cyan,magenta \"npm run dev:api\" \"npm run dev:mobile\"",
    "dev:api": "npm run dev -w api",
    "dev:app": "npm run dev -w app",
    "dev:mobile": "npm run start -w mobile",
    "build": "npm run build -w api && npm run build -w app",
    "db:migrate": "npm run db:migrate -w api",
    "db:seed": "npm run db:seed -w api",
    "test": "npm run test -w api",
    "deploy:fly": "fly deploy",
    "deploy:fly:admin": "fly deploy web/admin",
    "android": "npm run android -w mobile",
    "ios": "npm run ios -w mobile"
  },
  "version": "1.0.0",
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "dependencies": {
    "fixit": "file:",
    "expo": "~54.0.33",
    "react": "19.1.0",
    "react-native": "0.81.5"
  }
}
